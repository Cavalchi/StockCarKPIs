# ============================================================
# Stock Car KPIs — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e ajuste os valores:
#   cp .env.example .env
# ============================================================

# Conexão com o PostgreSQL (Docker padrão)
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stockcar_kpis

# URI completa (montada automaticamente pelo config.py, mas pode ser
# sobrescrita manualmente caso use um banco externo)
# DATABASE_URL=postgresql://admin:password@localhost:5432/stockcar_kpis
